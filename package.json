{
  "name": "git-ingest",
  "version": "0.2.4",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=26.0.0",
    "bun": ">=1.2.0"
  },
  "scripts": {
    "dev": "bun run dev:desktop",
    "build": "bun run --filter @git-ingest/core build && bun run --filter @git-ingest/cli build && bun run --filter @git-ingest/desktop build",
    "test": "bun run --filter @git-ingest/core test && bun run --filter @git-ingest/cli test && bun run --filter @git-ingest/desktop test",
    "test:smoke": "bun run --filter @git-ingest/desktop test:smoke",
    "dev:desktop": "bun run --filter @git-ingest/desktop dev",
    "build:desktop": "bun run --filter @git-ingest/desktop build",
    "package:desktop": "bun run --filter @git-ingest/desktop package",
    "ci:test": "bun run test && bun run test:smoke && bun run build",
    "ci:package:desktop": "bun run package:desktop",
    "build:cli": "bun run --filter @git-ingest/cli build",
    "format": "prettier --write --ignore-unknown '**/*.{ts,tsx,js,jsx,json,css,md}'",
    "postinstall": "node packages/desktop/node_modules/electron/install.js 2>/dev/null || true"
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
