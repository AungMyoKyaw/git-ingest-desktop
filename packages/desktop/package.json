{
  "name": "@git-ingest/desktop",
  "version": "0.1.0",
  "description": "Secure Electron desktop app for Git-Ingest",
  "author": "Aung Myo Kyaw",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "package": "electron-vite build && electron-builder --mac dmg zip",
    "test": "vitest run src/main/validators.test.ts src/main/file-actions.test.ts src/main/paths.test.ts src/main/state.test.ts src/renderer/src/drop.test.ts src/renderer/src/features/ingest/model/view-model.test.ts src/renderer/src/features/ingest/ui/Inspector.test.tsx",
    "test:smoke": "bun run build && vitest run src/smoke/launch.test.ts"
  },
  "dependencies": {
    "@git-ingest/core": "workspace:*",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "playwright": "^1.61.1",
    "tailwindcss": "^4.3.2",
    "vite": "^8.1.3"
  },
  "build": {
    "appId": "com.aungmyokyaw.git-ingest",
    "productName": "Git-Ingest",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "out/main/index.js"
    },
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "icon": "build/icons/icon.icns",
    "mac": {
      "icon": "build/icons/icon.icns",
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "win": {
      "icon": "build/icons/icon.ico"
    },
    "linux": {
      "icon": "build/icons/icon-512.png",
      "category": "Development"
    }
  }
}
